{
  "name": "hirify",
  "version": "1.0.0",
  "description": "Website platform untuk mencari pekerjaan dan mengelola karir",
  "scripts": {
    "dev": "npm run dev:services & npm run dev:frontend",
    "dev:services": "concurrently \"npm run dev:auth\" \"npm run dev:profile\" \"npm run dev:cv\" \"npm run dev:roadmap\" \"npm run dev:training\" \"npm run dev:mentorship\" \"npm run dev:jobmatching\" \"npm run dev:notification\" \"npm run dev:realtime\"",
    "dev:auth": "cd backend/auth-service && npm run dev",
    "dev:profile": "cd backend/profile-service && npm run dev",
    "dev:cv": "cd backend/cv-service && npm run dev",
    "dev:roadmap": "cd backend/roadmap-service && npm run dev",
    "dev:training": "cd backend/training-service && npm run dev",
    "dev:mentorship": "cd backend/mentorship-service && npm run dev",
    "dev:jobmatching": "cd backend/jobmatching-service && npm run dev",
    "dev:notification": "cd backend/notification-service && npm run dev",
    "dev:realtime": "cd backend/realtime-service && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "echo 'Backend services are Node.js apps, no build needed'",
    "seed": "node scripts/seedDatabase.js",
    "db:init": "node scripts/initDatabase.js"
  },
  "keywords": [
    "microservices",
    "nodejs",
    "express",
    "vue3",
    "mysql",
    "jwt"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.3",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.16.0",
    "node-cron": "^4.2.1",
    "npm-run-all": "^4.1.5",
    "pino": "^10.1.0",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "validator": "^13.15.23",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "main": "index.js",
  "type": "commonjs"
}
